@page "/"
@using MoaediPharamcy.Repositories
@using MoaediPharamcy.ViewModels
@using MudBlazor.Charts
@inject IDailySalesRepository SalesRepository

<PageTitle>داشبورد فروش</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-8">
    <!-- سرتیتر -->
    <MudStack Row="true" Spacing="2" Class="mb-6">
        <MudText Typo="Typo.h3" Class="text-primary font-weight-bold">📊 داشبورد فروش روزانه</MudText>
        <MudSpacer></MudSpacer>
        <MudDatePicker Label="انتخاب تاریخ" @bind-Date="SelectedDate" />
    </MudStack>

    @if (IsLoading)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else if (CurrentReport != null)
    {
        <!-- کارت‌های خلاصه فروش -->
        <MudGrid Spacing="2" Class="mb-6">
            <!-- کل فروش -->
            <MudItem xs="12" sm="6" md="3">
                <MudCard Class="mud-elevation-8">
                    <MudCardContent>
                        <div class="text-center">
                            <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Large" Class="text-success mb-2" />
                            <MudText Typo="Typo.caption" Class="text-muted">کل فروش</MudText>
                            <MudText Typo="Typo.h5" Class="font-weight-bold text-success">
                                @CurrentReport.TotalDailySales.ToString("N0")
                            </MudText>
                            <MudText Typo="Typo.caption" Class="text-muted">ریال</MudText>
                        </div>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- فروش بیمه‌ای -->
            <MudItem xs="12" sm="6" md="3">
                <MudCard Class="mud-elevation-8">
                    <MudCardContent>
                        <div class="text-center">
                            <MudIcon Icon="@Icons.Material.Filled.HealthAndSafety" Size="Size.Large" Class="text-info mb-2" />
                            <MudText Typo="Typo.caption" Class="text-muted">فروش بیمه‌ای</MudText>
                            <MudText Typo="Typo.h5" Class="font-weight-bold text-info">
                                @CurrentReport.TotalInsuranceSales.ToString("N0")
                            </MudText>
                            <MudText Typo="Typo.caption">@CurrentReport.InsuranceSalesPercentage.ToString("F1")%</MudText>
                        </div>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- مبلغ قابل پرداخت -->
            <MudItem xs="12" sm="6" md="3">
                <MudCard Class="mud-elevation-8">
                    <MudCardContent>
                        <div class="text-center">
                            <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Large" Class="text-warning mb-2" />
                            <MudText Typo="Typo.caption" Class="text-muted">قابل پرداخت</MudText>
                            <MudText Typo="Typo.h5" Class="font-weight-bold text-warning">
                                @CurrentReport.TotalPayablePrice.ToString("N0")
                            </MudText>
                            <MudText Typo="Typo.caption" Class="text-muted">ریال</MudText>
                        </div>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- مبلغ معوق -->
            <MudItem xs="12" sm="6" md="3">
                <MudCard Class="mud-elevation-8">
                    <MudCardContent>
                        <div class="text-center">
                            <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Large" Class="@(CurrentReport.OutstandingAmount > 0 ? "text-danger" : "text-success") mb-2" />
                            <MudText Typo="Typo.caption" Class="text-muted">معوق</MudText>
                            <MudText Typo="Typo.h5" Class="font-weight-bold @(CurrentReport.OutstandingAmount > 0 ? "text-danger" : "text-success")">
                                @CurrentReport.OutstandingAmount.ToString("N0")
                            </MudText>
                            <MudText Typo="Typo.caption" Class="text-muted">ریال</MudText>
                        </div>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>

        <!-- چارت‌ها -->
        <MudGrid Spacing="2" Class="mb-6">
            <!-- چارت دونات - نسبت فروش -->
            <MudItem xs="12" md="6">
                <MudCard Class="mud-elevation-8">
                    <MudCardHeader>
                        <MudText Typo="Typo.h6">توزیع فروش (بیمه‌ای vs غیر بیمه‌ای)</MudText>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudChart ChartType="ChartType.Donut" ChartSeries="@Series1" @bind-SelectedIndex="SelectedIndex1" ChartOptions="@ChartOptions" />
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- چارت ستونی - اجزای فروش -->
            <MudItem xs="12" md="6">
                <MudCard Class="mud-elevation-8">
                    <MudCardHeader>
                        <MudText Typo="Typo.h6">اجزای فروش</MudText>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudChart ChartType="ChartType.Bar" ChartSeries="@Series2" @bind-SelectedIndex="SelectedIndex2" ChartOptions="@ChartOptions" XAxisLabels="@XAxisLabels" />
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>

        <!-- چارت‌های اضافی -->
        <MudGrid Spacing="2" Class="mb-6">
            <!-- چارت ستونی - سهم‌ها -->
            <MudItem xs="12" md="6">
                <MudCard Class="mud-elevation-8">
                    <MudCardHeader>
                        <MudText Typo="Typo.h6">تقسیم سهم‌ها</MudText>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudChart ChartType="ChartType.Bar" ChartSeries="@Series3" @bind-SelectedIndex="SelectedIndex3" ChartOptions="@ChartOptions" XAxisLabels="@XAxisLabels2" />
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- چارت خطی - مقایسه مالی -->
            <MudItem xs="12" md="6">
                <MudCard Class="mud-elevation-8">
                    <MudCardHeader>
                        <MudText Typo="Typo.h6">مقایسه قابل پرداخت و پرداخت‌شده</MudText>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudChart ChartType="ChartType.Line" ChartSeries="@Series4" @bind-SelectedIndex="SelectedIndex4" ChartOptions="@ChartOptions" XAxisLabels="@XAxisLabels3" />
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>

        <!-- جدول جزئیات -->
        <MudCard Class="mud-elevation-8 mb-6">
            <MudCardHeader>
                <MudText Typo="Typo.h6">جزئیات فروش</MudText>
            </MudCardHeader>
            <MudCardContent>
                <MudSimpleTable Bordered="true" Dense="true" Hover="true" FixedHeader="true" Style="max-height: 400px; overflow-y: auto;">
                    <thead>
                        <tr>
                            <th>شرح</th>
                            <th class="text-right">مبلغ (ریال)</th>
                            <th class="text-right">درصد</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>کل فروش</td>
                            <td class="text-right font-weight-bold text-success">@CurrentReport.TotalDailySales.ToString("N0")</td>
                            <td class="text-right">100%</td>
                        </tr>
                        <tr>
                            <td>فروش بیمه‌ای</td>
                            <td class="text-right">@CurrentReport.TotalInsuranceSales.ToString("N0")</td>
                            <td class="text-right">@CurrentReport.InsuranceSalesPercentage.ToString("F1")%</td>
                        </tr>
                        <tr>
                            <td>فروش غیر بیمه‌ای</td>
                            <td class="text-right">@CurrentReport.TotalNonInsuranceSales.ToString("N0")</td>
                            <td class="text-right">@CurrentReport.NonInsuranceSalesPercentage.ToString("F1")%</td>
                        </tr>
                        <tr>
                            <td>سهم سازمان</td>
                            <td class="text-right font-weight-bold text-info">@CurrentReport.TotalOrganPart.ToString("N0")</td>
                            <td class="text-right">@((CurrentReport.TotalDailySales > 0 ? (CurrentReport.TotalOrganPart / CurrentReport.TotalDailySales * 100) : 0).ToString("F1"))%</td>
                        </tr>
                        <tr>
                            <td>سهم بیمار</td>
                            <td class="text-right">@CurrentReport.TotalSickPart.ToString("N0")</td>
                            <td class="text-right">@((CurrentReport.TotalDailySales > 0 ? (CurrentReport.TotalSickPart / CurrentReport.TotalDailySales * 100) : 0).ToString("F1"))%</td>
                        </tr>
                        <tr>
                            <td>سهم ارز</td>
                            <td class="text-right">@CurrentReport.TotalExchangePrice.ToString("N0")</td>
                            <td class="text-right">-</td>
                        </tr>
                        <tr>
                            <td>تعرفه خدمات دارویی</td>
                            <td class="text-right">@CurrentReport.TotalPharmacyServiceFee.ToString("N0")</td>
                            <td class="text-right">-</td>
                        </tr>
                        <tr Class="mud-table-row mud-elevation-1">
                            <td>مبلغ قابل پرداخت</td>
                            <td class="text-right font-weight-bold text-warning">@CurrentReport.TotalPayablePrice.ToString("N0")</td>
                            <td class="text-right">-</td>
                        </tr>
                        <tr Class="mud-table-row mud-elevation-1">
                            <td>مبلغ پرداخت‌شده</td>
                            <td class="text-right font-weight-bold text-success">@CurrentReport.TotalPaidPrice.ToString("N0")</td>
                            <td class="text-right">@CurrentReport.CollectionRatio.ToString("F1")%</td>
                        </tr>
                        <tr Class="mud-table-row mud-elevation-1">
                            <td>مبلغ معوق</td>
                            <td class="text-right font-weight-bold @(CurrentReport.OutstandingAmount > 0 ? "text-danger" : "text-success")">@CurrentReport.OutstandingAmount.ToString("N0")</td>
                            <td class="text-right">@((CurrentReport.TotalPayablePrice > 0 ? (CurrentReport.OutstandingAmount / CurrentReport.TotalPayablePrice * 100) : 0).ToString("F1"))%</td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudCardContent>
        </MudCard>

        <!-- آمار اضافی -->
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6" md="3">
                <MudCard Class="mud-elevation-8">
                    <MudCardContent>
                        <div class="text-center">
                            <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Large" Class="text-secondary mb-2" />
                            <MudText Typo="Typo.caption" Class="text-muted">تعداد فاکتورها</MudText>
                            <MudText Typo="Typo.h5" Class="font-weight-bold">@CurrentReport.TotalInvoices</MudText>
                        </div>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudCard Class="mud-elevation-8">
                    <MudCardContent>
                        <div class="text-center">
                            <MudIcon Icon="@Icons.Material.Filled.LocalPharmacy" Size="Size.Large" Class="text-secondary mb-2" />
                            <MudText Typo="Typo.caption" Class="text-muted">تعداد اقلام</MudText>
                            <MudText Typo="Typo.h5" Class="font-weight-bold">@CurrentReport.TotalItems</MudText>
                        </div>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudCard Class="mud-elevation-8">
                    <MudCardContent>
                        <div class="text-center">
                            <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Large" Class="text-secondary mb-2" />
                            <MudText Typo="Typo.caption" Class="text-muted">میانگین فروش/فاکتور</MudText>
                            <MudText Typo="Typo.h5" Class="font-weight-bold">@CurrentReport.AverageSalesPerInvoice.ToString("N0")</MudText>
                        </div>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudCard Class="mud-elevation-8">
                    <MudCardContent>
                        <div class="text-center">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Class="text-secondary mb-2" />
                            <MudText Typo="Typo.caption" Class="text-muted">نسبت جمع‌آوری</MudText>
                            <MudText Typo="Typo.h5" Class="font-weight-bold @(CurrentReport.CollectionRatio >= 80 ? "text-success" : CurrentReport.CollectionRatio >= 50 ? "text-warning" : "text-danger")">
                                @CurrentReport.CollectionRatio.ToString("F1")%
                            </MudText>
                        </div>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    }
    else if (!IsLoading)
    {
        <MudAlert Severity="Severity.Warning">هیچ داده‌ای برای روز انتخاب‌شده پیدا نشد.</MudAlert>
    }
</MudContainer>

@code {
    private DailySalesReportViewModel CurrentReport;
    private DateTime? SelectedDate = DateTime.Now;
    private bool IsLoading = true;
    private int SelectedIndex1 = -1;
    private int SelectedIndex2 = -1;
    private int SelectedIndex3 = -1;
    private int SelectedIndex4 = -1;

    private List<ChartSeries> Series1 = new();
    private List<ChartSeries> Series2 = new();
    private List<ChartSeries> Series3 = new();
    private List<ChartSeries> Series4 = new();

    private List<string> XAxisLabels = new();
    private List<string> XAxisLabels2 = new();
    private List<string> XAxisLabels3 = new();

    private ChartOptions ChartOptions = new()
    {
        ChartPalette = new[] { "#4CAF50", "#2196F3", "#FF9800", "#F44336", "#9C27B0", "#00BCD4" },
        DisableLegend = false,
        LineStrokeWidth = 2,
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadDailySalesReport();
    }

    private async Task LoadDailySalesReport()
    {
        try
        {
            IsLoading = true;
            StateHasChanged();

            if (SelectedDate.HasValue)
            {
                // تبدیل تاریخ میلادی به شمسی
                var shamsiDate = ConvertToShamsi(SelectedDate.Value);
                CurrentReport = await SalesRepository.GetDailySalesReportAsync(shamsiDate.Year, shamsiDate.Month, shamsiDate.Day);

                if (CurrentReport != null)
                {
                    UpdateCharts();
                }
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Error: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void UpdateCharts()
    {
        if (CurrentReport == null) return;

        // چارت 1: دونات - بیمه‌ای vs غیر بیمه‌ای
        Series1 = new List<ChartSeries>
        {
            new ChartSeries { Name = "بیمه‌ای", Data = new double[] { (double)CurrentReport.TotalInsuranceSales } },
            new ChartSeries { Name = "غیر بیمه‌ای", Data = new double[] { (double)CurrentReport.TotalNonInsuranceSales } }
        };

        // چارت 2: ستونی - اجزای فروش
        Series2 = new List<ChartSeries>
        {
            new ChartSeries { Name = "بیمه‌ای", Data = new double[] { (double)CurrentReport.TotalInsuranceSales } },
            new ChartSeries { Name = "غیر بیمه‌ای", Data = new double[] { (double)CurrentReport.TotalNonInsuranceSales } },
            new ChartSeries { Name = "سهم سازمان", Data = new double[] { (double)CurrentReport.TotalOrganPart } }
        };
        XAxisLabels = new List<string> { "مقادیر" };

        // چارت 3: ستونی - سهم‌ها
        Series3 = new List<ChartSeries>
        {
            new ChartSeries { Name = "سهم سازمان", Data = new double[] { (double)CurrentReport.TotalOrganPart } },
            new ChartSeries { Name = "سهم بیمار", Data = new double[] { (double)CurrentReport.TotalSickPart } },
            new ChartSeries { Name = "سهم ارز", Data = new double[] { (double)CurrentReport.TotalExchangePrice } },
            new ChartSeries { Name = "تعرفه خدمات", Data = new double[] { (double)CurrentReport.TotalPharmacyServiceFee } }
        };
        XAxisLabels2 = new List<string> { "مقادیر" };

        // چارت 4: خطی - مقایسه مالی
        Series4 = new List<ChartSeries>
        {
            new ChartSeries { Name = "قابل پرداخت", Data = new double[] { (double)CurrentReport.TotalPayablePrice } },
            new ChartSeries { Name = "پرداخت‌شده", Data = new double[] { (double)CurrentReport.TotalPaidPrice } },
            new ChartSeries { Name = "معوق", Data = new double[] { (double)CurrentReport.OutstandingAmount } }
        };
        XAxisLabels3 = new List<string> { "وضعیت" };

        StateHasChanged();
    }

    private async Task SelectedDateChanged(DateTime? newDate)
    {
        SelectedDate = newDate;
        await LoadDailySalesReport();
    }

    private (int Year, int Month, int Day) ConvertToShamsi(DateTime date)
    {
        // تبدیل ساده - به جای این، می‌توانید از کتابخانه‌های مخصوص استفاده کنید
        // این یک نمونه ساده است
        return (1405, 3, 27); // نمونه
    }
}
