@page "/sales-report"
@page "/sales-report/{Year:int}/{Month:int}/{Day:int}"
@using MoaediPharamcy.ViewModels
@using MoaediPharamcy.Repositories
@inject IDailySalesRepository SalesRepository
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<style>
    .sales-report-container {
        padding: 20px;
    }

    .report-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 20px;
    }

    .metric-card {
        background: white;
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        margin-bottom: 15px;
    }

    .metric-value {
        font-size: 24px;
        font-weight: bold;
        color: #333;
    }

    .metric-label {
        font-size: 14px;
        color: #666;
        margin-top: 5px;
    }

    .metric-positive {
        color: #4caf50;
    }

    .metric-warning {
        color: #ff9800;
    }

    .metric-danger {
        color: #f44336;
    }

    .date-picker {
        margin-bottom: 20px;
    }
</style>

<div class="sales-report-container">
    <!-- هدر گزارش -->
    <MudPaper Class="report-header">
        <MudText Typo="Typo.h4" Class="font-weight-bold mb-2">
            <MudIcon Icon="@Icons.Material.Filled.SalesChart" />
            گزارش فروش روزانه
        </MudText>
        <MudText Typo="Typo.body1">
            خلاصه فروش، سهم بیمار و سهم سازمان
        </MudText>
    </MudPaper>

    @if (_isLoading)
    {
        <MudProgressLinear Color="MudBlazor.Color.Primary" Indeterminate="true" Class="mb-4" />
    }
    else
    {
        <!-- انتخاب تاریخ -->
        <MudPaper Class="pa-6 mb-4 date-picker">
            <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">
                انتخاب تاریخ (سال / ماه / روز شمسی)
            </MudText>
            <MudGrid>
                <MudItem xs="12" md="3">
                    <MudNumericField @bind-Value="_selectedYear" Label="سال" Min="1400" Max="1410" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudNumericField @bind-Value="_selectedMonth" Label="ماه" Min="1" Max="12" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudNumericField @bind-Value="_selectedDay" Label="روز" Min="1" Max="31" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" 
                               OnClick="LoadReportAsync" FullWidth="true" Class="mt-1">
                        جستجو
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @if (_report != null)
        {
            <!-- خلاصه مالی -->
            <MudGrid>
                <!-- مجموع فروش روزانه -->
                <MudItem xs="12" md="6" lg="3">
                    <MudPaper Class="metric-card">
                        <MudText Typo="Typo.caption" Class="metric-label">
                            <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Size="MudBlazor.Size.Small" />
                            مجموع فروش روزانه
                        </MudText>
                        <MudText Class="metric-value metric-positive">
                            @_report.TotalDailySales.ToString("N0")
                        </MudText>
                        <MudText Typo="Typo.caption" Class="metric-label">
                            ریال
                        </MudText>
                    </MudPaper>
                </MudItem>

                <!-- سهم بیمار -->
                <MudItem xs="12" md="6" lg="3">
                    <MudPaper Class="metric-card">
                        <MudText Typo="Typo.caption" Class="metric-label">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="MudBlazor.Size.Small" />
                            مجموع سهم بیمار
                        </MudText>
                        <MudText Class="metric-value metric-warning">
                            @_report.TotalSickPart.ToString("N0")
                        </MudText>
                        <MudText Typo="Typo.caption" Class="metric-label">
                            ریال
                        </MudText>
                    </MudPaper>
                </MudItem>

                <!-- سهم سازمان -->
                <MudItem xs="12" md="6" lg="3">
                    <MudPaper Class="metric-card">
                        <MudText Typo="Typo.caption" Class="metric-label">
                            <MudIcon Icon="@Icons.Material.Filled.Business" Size="MudBlazor.Size.Small" />
                            مجموع سهم سازمان
                        </MudText>
                        <MudText Class="metric-value metric-positive">
                            @_report.TotalOrganPart.ToString("N0")
                        </MudText>
                        <MudText Typo="Typo.caption" Class="metric-label">
                            ریال
                        </MudText>
                    </MudPaper>
                </MudItem>

                <!-- مبلغ قابل پرداخت -->
                <MudItem xs="12" md="6" lg="3">
                    <MudPaper Class="metric-card">
                        <MudText Typo="Typo.caption" Class="metric-label">
                            <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="MudBlazor.Size.Small" />
                            مبلغ قابل پرداخت
                        </MudText>
                        <MudText Class="metric-value metric-positive">
                            @_report.TotalPayablePrice.ToString("N0")
                        </MudText>
                        <MudText Typo="Typo.caption" Class="metric-label">
                            ریال
                        </MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <!-- جدول جزئیات -->
            <MudPaper Class="pa-4 mb-4">
                <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.TableChart" />
                    جزئیات گزارش
                </MudText>

                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudCard>
                            <MudCardContent>
                                <MudText Typo="Typo.subtitle2" Class="font-weight-bold mb-3">فروش</MudText>
                                
                                <div class="d-flex justify-space-between mb-2">
                                    <MudText Typo="Typo.body2">تعداد فاکتورها:</MudText>
                                    <MudText Typo="Typo.body2" Class="font-weight-bold">@_report.TotalInvoices</MudText>
                                </div>
                                
                                <div class="d-flex justify-space-between mb-2">
                                    <MudText Typo="Typo.body2">تعداد اقلام:</MudText>
                                    <MudText Typo="Typo.body2" Class="font-weight-bold">@_report.TotalItems</MudText>
                                </div>

                                <MudDivider Class="my-2" />
                                
                                <div class="d-flex justify-space-between mb-2">
                                    <MudText Typo="Typo.body2">فروش بیمه‌ای:</MudText>
                                    <MudText Typo="Typo.body2" Class="font-weight-bold">
                                        @_report.TotalInsuranceSales.ToString("N0")
                                    </MudText>
                                </div>

                                <div class="d-flex justify-space-between mb-2">
                                    <MudText Typo="Typo.body2">درصد بیمه‌ای:</MudText>
                                    <MudText Typo="Typo.body2" Class="font-weight-bold">
                                        @_report.InsuranceSalesPercentage.ToString("F2")%
                                    </MudText>
                                </div>

                                <div class="d-flex justify-space-between mb-2">
                                    <MudText Typo="Typo.body2">فروش غیر بیمه‌ای:</MudText>
                                    <MudText Typo="Typo.body2" Class="font-weight-bold">
                                        @_report.TotalNonInsuranceSales.ToString("N0")
                                    </MudText>
                                </div>

                                <div class="d-flex justify-space-between">
                                    <MudText Typo="Typo.body2">درصد غیر بیمه‌ای:</MudText>
                                    <MudText Typo="Typo.body2" Class="font-weight-bold">
                                        @_report.NonInsuranceSalesPercentage.ToString("F2")%
                                    </MudText>
                                </div>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudCard>
                            <MudCardContent>
                                <MudText Typo="Typo.subtitle2" Class="font-weight-bold mb-3">سهم و پرداخت</MudText>
                                
                                <div class="d-flex justify-space-between mb-2">
                                    <MudText Typo="Typo.body2">سهم ارز:</MudText>
                                    <MudText Typo="Typo.body2" Class="font-weight-bold">
                                        @_report.TotalExchangePrice.ToString("N0")
                                    </MudText>
                                </div>
                                
                                <div class="d-flex justify-space-between mb-2">
                                    <MudText Typo="Typo.body2">تعرفه خدمات:</MudText>
                                    <MudText Typo="Typo.body2" Class="font-weight-bold">
                                        @_report.TotalPharmacyServiceFee.ToString("N0")
                                    </MudText>
                                </div>

                                <MudDivider Class="my-2" />
                                
                                <div class="d-flex justify-space-between mb-2">
                                    <MudText Typo="Typo.body2">مبلغ پرداخت‌شده:</MudText>
                                    <MudText Typo="Typo.body2" Class="font-weight-bold metric-positive">
                                        @_report.TotalPaidPrice.ToString("N0")
                                    </MudText>
                                </div>

                                <div class="d-flex justify-space-between mb-2">
                                    <MudText Typo="Typo.body2">نسبت جمع‌آوری:</MudText>
                                    <MudText Typo="Typo.body2" Class="font-weight-bold">
                                        @_report.CollectionRatio.ToString("F2")%
                                    </MudText>
                                </div>

                                <div class="d-flex justify-space-between">
                                    <MudText Typo="Typo.body2">مبلغ معوق:</MudText>
                                    <MudText Typo="Typo.body2" Class="font-weight-bold metric-danger">
                                        @_report.OutstandingAmount.ToString("N0")
                                    </MudText>
                                </div>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <!-- میانگین‌ها -->
            <MudPaper Class="pa-4 mb-4">
                <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.Analytics" />
                    میانگین‌ها
                </MudText>

                <MudGrid>
                    <MudItem xs="12" md="6">
                        <div class="d-flex justify-space-between mb-3 pa-3" style="background: #f5f5f5; border-radius: 8px;">
                            <MudText Typo="Typo.body2">میانگین فروش به ازای هر فاکتور:</MudText>
                            <MudText Typo="Typo.body2" Class="font-weight-bold">
                                @_report.AverageSalesPerInvoice.ToString("N0") ریال
                            </MudText>
                        </div>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <div class="d-flex justify-space-between mb-3 pa-3" style="background: #f5f5f5; border-radius: 8px;">
                            <MudText Typo="Typo.body2">میانگین قابل پرداخت به ازای هر فاکتور:</MudText>
                            <MudText Typo="Typo.body2" Class="font-weight-bold">
                                @_report.AveragePayablePerInvoice.ToString("N0") ریال
                            </MudText>
                        </div>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <!-- دکمه‌های عملیات -->
            <MudPaper Class="pa-4 d-flex gap-2 justify-center">
                <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" 
                           StartIcon="@Icons.Material.Filled.Print" OnClick="PrintReport">
                    چاپ گزارش
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="MudBlazor.Color.Primary" 
                           StartIcon="@Icons.Material.Filled.FileDownload" OnClick="ExportToExcel">
                    خروجی Excel
                </MudButton>
                <MudButton Variant="Variant.Text" Color="MudBlazor.Color.Default" 
                           StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack">
                    بازگشت
                </MudButton>
            </MudPaper>
        }
    }
</div>

@code {
    private DailySalesReportViewModel? _report;
    private bool _isLoading = false;
    private int _selectedYear = 1405;
    private int _selectedMonth = 3;
    private int _selectedDay = 27;

    protected override async Task OnInitializedAsync()
    {
        await LoadReportAsync();
    }

    private async Task LoadReportAsync()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            _report = await SalesRepository.GetDailySalesReportAsync(
                _selectedYear,
                _selectedMonth,
                _selectedDay);

            if (_report == null)
            {
                Snackbar.Add("گزارشی برای این تاریخ یافت نشد", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"خطا در دریافت گزارش: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void PrintReport()
    {
        Snackbar.Add("در حال آماده‌سازی برای چاپ...", Severity.Info);
        // منطق چاپ را اینجا اضافه کنید
    }

    private void ExportToExcel()
    {
        Snackbar.Add("در حال خروجی به Excel...", Severity.Info);
        // منطق خروجی Excel را اینجا اضافه کنید
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/");
    }
}
